# 노션 인테그레이션 토큰 (https://www.notion.so/my-integrations 에서 발급)
# 서버 사이드 전용 — 절대 클라이언트에 노출하지 마세요.
NOTION_API_TOKEN=

# 견적서(Invoices) 데이터베이스 ID
# 품목(Items) DB는 Invoices DB의 "항목"(Relation) 속성으로 자동 발견됩니다.
NOTION_DATABASE_ID=

# 애플리케이션 베이스 URL
# 로컬: http://localhost:3000 / 프로덕션: 배포된 실제 도메인
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# 관리자 비밀번호 (최소 1자 이상)
ADMIN_PASSWORD=your_admin_password_here

# 세션 인증 시크릿 (최소 32자 권장, openssl rand -base64 32로 생성)
AUTH_SECRET=your_auth_secret_here
